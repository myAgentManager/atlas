# Copy to .env and adjust. Everything has a sane default — myAgent runs fully
# self-contained with zero configuration. ATLAS Core (the built-in, from-scratch
# AI engine) needs no API keys and no model downloads.

# --- identity ----------------------------------------------------------------
MYAGENT_NAME=ATLAS

# --- server ports --------------------------------------------------------------
PORT=8787          # main app
ADMIN_PORT=8788    # admin console (separate port, code-locked)
# On single-port cloud hosts (Render etc.) set ADMIN_MOUNT=path to serve the
# admin console at /atlas-admin on the main port instead.
# ADMIN_MOUNT=path
# Behind a reverse proxy / cloud host, enable proxy trust + Secure cookies:
# TRUST_PROXY=1

# --- cloud database (free tier: Neon or Supabase Postgres) -----------------------
# When set, users, tasks, sessions, and every account's private files live in
# Postgres instead of local disk — required on hosts with ephemeral filesystems.
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# --- admin console ---------------------------------------------------------------
# The unlock code for the admin console (any length, letters welcome).
ADMIN_CODE=782677
# (IP allowlisting removed — the console is protected by ADMIN_CODE only.)
# Localhost is always allowed. Comma-separate multiple addresses.

# --- sessions ----------------------------------------------------------------------
# Session-signing secret. Auto-generated into data/.secret if unset.
# MYAGENT_SECRET=

# --- Twilio SMS (optional, server-wide) ----------------------------------------------
# Server owner's Twilio credentials; each account sets its own destination
# number in Settings → Notifications.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+15555550123
